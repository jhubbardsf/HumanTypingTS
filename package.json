{
  "name": "humantyping-ts",
  "version": "0.1.0",
  "description": "Realistic human typing simulation for TypeScript and Playwright.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:smoke": "PLAYWRIGHT_SMOKE=1 bun test test/playwright-smoke.test.ts"
  },
  "keywords": [
    "typing",
    "simulation",
    "markov-chain",
    "automation",
    "playwright",
    "human-behavior",
    "browser-automation",
    "testing"
  ],
  "license": "MIT",
  "peerDependencies": {
    "playwright": "^1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "playwright": "^1.40.0",
    "typescript": "^6.0.3"
  }
}
